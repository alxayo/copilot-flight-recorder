# Copilot Audit Hooks Configuration
# Copy this file to .env and update the values.

# Required: Absolute path to the git repository used for audit logs.
COPILOT_AUDIT_REPO=/path/to/audit-repo

# Branching mode: "flat" (all commits on one branch) or "per-session" (one branch per chat session).
# Default: flat
COPILOT_AUDIT_MODE=flat

# Branch name used in flat mode.
# Default: main
COPILOT_AUDIT_BRANCH=main

# Auto-push the audit branch when a session ends: "true" or "false".
# Default: false
COPILOT_AUDIT_PUSH=false
